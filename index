<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com" rel="stylesheet">
  
  <style>
    :root {
      --bg: #050508; --card: #0d0d12; --accent: #7c4dff; 
      --accent-glow: rgba(124, 77, 255, 0.2); --yellow: #ccff00; 
      --border: rgba(255, 255, 255, 0.08); --ink: #ffffff; 
      --muted: #80808e; --cyan: #00f2ff; --green: #00ffa3; 
    }
    * { box-sizing: border-box; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
    body { 
      font-family: 'Inter', sans-serif; background: var(--bg); color: var(--ink); margin: 0; padding: 15px;
      background-image: radial-gradient(circle at 50% -20%, #1a1a35 0%, transparent 70%);
      min-height: 100vh;
    }
    .app { width: 100%; max-width: 1300px; margin: 0 auto; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 24px; margin-bottom: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); backdrop-filter: blur(20px); }
    h3 { font-family: 'Orbitron', sans-serif; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 3px; margin-bottom: 24px; }
    .bal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .bal-card { background: linear-gradient(145deg, #16161f, #0d0d12); border: 1px solid var(--border); border-radius: 24px; padding: 24px; position: relative; overflow: hidden; }
    .bal-amt { font-family: 'Orbitron', sans-serif; font-size: 30px; font-weight: 700; color: #fff; margin: 10px 0; }
    #wBal { color: var(--green); text-shadow: 0 0 25px rgba(0, 255, 163, 0.3); }
    #bBal { color: var(--cyan); text-shadow: 0 0 25px rgba(0, 242, 255, 0.3); }
    .blurred { filter: blur(15px); opacity: 0.3; user-select: none; }
    .main-layout { display: grid; grid-template-columns: 2fr 1.1fr; gap: 25px; }
    input, select { width: 100%; padding: 14px; border-radius: 14px; border: 1px solid var(--border); background: #12121a; color: #fff; margin-bottom: 12px; font-size: 10px; }
    .btn { padding: 16px; border-radius: 16px; border: none; font-weight: 700; cursor: pointer; width: 100%; text-transform: uppercase; font-size: 11px; font-family: 'Orbitron', sans-serif; }
    .mpesa { background: var(--green); color: #000; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    @media (max-width: 850px) { .main-layout, .bal-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="app">
    <div class="card">
      <h3>Active Debtor Matrix // Global Nodes</h3>
      <div id="debtorGrid" style="color: var(--muted); font-size: 10px;">Syncing nodes...</div>
    </div>

    <div class="bal-grid">
      <div class="bal-card">
        <small style="color:var(--yellow); font-size:8px;">M-PESA_CORE</small>
        <div class="bal-amt" id="wBal">KSh 0.00</div>
        <button onclick="sync()" style="background:none; border:none; color:var(--muted); cursor:pointer; font-size:8px;">[ REFRESH ]</button>
      </div>
      <div class="bal-card" onclick="unlockBank()">
        <small style="color:var(--cyan); font-size:8px;">BANK_RESERVE (LOCKED)</small>
        <div class="bal-amt blurred" id="bBal">KSh 0.00</div>
      </div>
    </div>

    <div class="main-layout">
      <div class="card">
        <h3>Expenditure Clearance Terminal</h3>
        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:8px">
          <input type="date" id="purDate">
          <select id="selEntInput"><option>Loading...</option></select>
          <select id="selProj"><option>Loading...</option></select>
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr 100px; gap:8px">
          <select id="selCat"><option>Loading...</option></select>
          <input type="text" id="merchant" placeholder="MERCHANT">
          <input type="number" id="totalAmt" placeholder="TOTAL">
        </div>
        <button id="authBtn" class="btn mpesa" onclick="submitPurchase()">Authorize Purchase</button>
      </div>
    </div>
  </div>

  <script>
    const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbwM4J7udV76paiu0Jb6HIZHkte3ac3Ec5orFEY9DeikE6hiHhGbuKqkZSxN7DuX1uWI/exec";

    // Replaces google.script.run for GitHub
    async function callAPI(action, args = {}) {
      try {
        // We use POST for everything to avoid URL length issues and CORS hangups
        const response = await fetch(WEB_APP_URL, {
          method: 'POST',
          body: JSON.stringify({ action: action, data: args })
        });
        return await response.json();
      } catch (e) {
        console.error("API Error", e);
        return null;
      }
    }

    async function sync() {
      const wBalDiv = document.getElementById('wBal');
      wBalDiv.innerText = "LOADING...";
      
      const data = await callAPI('getAppData', { selectedEntity: 'All' });
      
      if (data) {
        wBalDiv.innerText = `KSh ${parseFloat(data.walletBal).toLocaleString()}`;
        document.getElementById('bBal').innerText = `KSh ${parseFloat(data.bankBal).toLocaleString()}`;
        
        populateSelect('selEntInput', data.entities);
        populateSelect('selProj', data.projects);
        populateSelect('selCat', data.categories);
      }
    }

    async function submitPurchase() {
      const btn = document.getElementById('authBtn');
      const data = {
        date: document.getElementById('purDate').value || new Date().toISOString(),
        entity: document.getElementById('selEntInput').value,
        project: document.getElementById('selProj').value,
        merchant: document.getElementById('merchant').value,
        category: document.getElementById('selCat').value,
        total: document.getElementById('totalAmt').value,
        source: "WALLET"
      };

      if(!data.total || !data.merchant) return alert("Missing Amount or Merchant!");

      btn.disabled = true;
      btn.innerText = "PROCESSING...";

      const res = await callAPI('processPurchase', data);
      
      if (res && res.status === "SUCCESS") {
        alert("Transaction Recorded!");
        document.getElementById('merchant').value = "";
        document.getElementById('totalAmt').value = "";
        sync();
      } else {
        alert("Save Failed. Check Apps Script.");
      }
      btn.disabled = false;
      btn.innerText = "Authorize Purchase";
    }

    function populateSelect(id, list) {
      const el = document.getElementById(id);
      if(list && list.length > 0) {
        el.innerHTML = list.map(i => `<option value="${i}">${i}</option>`).join('');
      }
    }

    function unlockBank() {
      const pin = prompt("Enter Vault PIN:");
      if (pin === "1234") document.getElementById('bBal').classList.remove('blurred');
    }

    window.onload = sync;
  </script>
</body>
</html>
