<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Morgenroth Manager | Global</title>
  <link href="https://fonts.googleapis.com" rel="stylesheet">
  <style>
    :root {
      --bg: #050508; --card: #0d0d12; --accent: #7c4dff; --yellow: #ccff00;
      --border: rgba(255, 255, 255, 0.08); --ink: #ffffff; --muted: #80808e;
      --cyan: #00f2ff; --green: #00ffa3;
    }
    body { 
      font-family: 'Inter', sans-serif; background: var(--bg); color: var(--ink); margin: 0; padding: 15px;
      background-image: radial-gradient(circle at 50% -20%, #1a1a35 0%, transparent 70%);
      min-height: 100vh;
    }
    .app { width: 100%; max-width: 1200px; margin: 0 auto; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 24px; margin-bottom: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); }
    h3 { font-family: 'Orbitron', sans-serif; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 3px; }
    .bal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .bal-card { background: linear-gradient(145deg, #16161f, #0d0d12); border: 1px solid var(--border); border-radius: 24px; padding: 24px; }
    .bal-amt { font-family: 'Orbitron', sans-serif; font-size: 32px; font-weight: 700; margin: 10px 0; }
    #wBal { color: var(--green); } #bBal { color: var(--cyan); }
    input, select { width: 100%; padding: 14px; border-radius: 12px; border: 1px solid var(--border); background: #12121a; color: #fff; margin-bottom: 12px; font-size: 12px; }
    .btn { padding: 16px; border-radius: 16px; border: none; font-weight: 700; cursor: pointer; width: 100%; text-transform: uppercase; font-family: 'Orbitron'; letter-spacing: 1px; }
    .mpesa { background: var(--green); color: #000; }
    .history-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 12px; }
    .history-table td { padding: 12px; border-bottom: 1px solid var(--border); }
  </style>
</head>
<body>

<div class="app">
  <div class="bal-grid">
    <div class="bal-card">
      <h3>Wallet Balance</h3>
      <div class="bal-amt" id="wBal">KSh 0.00</div>
    </div>
    <div class="bal-card">
      <h3>Bank Reserve</h3>
      <div class="bal-amt" id="bBal">KSh 0.00</div>
    </div>
  </div>

  <div class="card">
    <h3>New Transaction</h3>
    <input type="date" id="date">
    <input type="text" id="merchant" placeholder="Merchant Name">
    <input type="number" id="amount" placeholder="Amount (KSh)">
    <select id="source">
      <option value="WALLET">Wallet</option>
      <option value="BANK">Bank</option>
    </select>
    <button class="btn mpesa" onclick="addTransaction()">Authorize</button>
  </div>

  <div class="card">
    <h3>Recent Ledger</h3>
    <table class="history-table" id="historyTable">
      <!-- Data injected here -->
    </table>
  </div>
</div>

<script>
  // INITIALIZE DATA FROM LOCALSTORAGE
  let transactions = JSON.parse(localStorage.getItem('morgenroth_data')) || [];

  function updateUI() {
    let wallet = 0; let bank = 0;
    const table = document.getElementById('historyTable');
    table.innerHTML = "";

    transactions.forEach(t => {
      if (t.source === "WALLET") wallet -= t.amount;
      if (t.source === "BANK") bank -= t.amount;

      let row = `<tr><td>${t.date}</td><td>${t.merchant}</td><td>KSh ${t.amount.toLocaleString()}</td><td>${t.source}</td></tr>`;
      table.innerHTML += row;
    });

    document.getElementById('wBal').innerText = `KSh ${wallet.toLocaleString()}`;
    document.getElementById('bBal').innerText = `KSh ${bank.toLocaleString()}`;
  }

  function addTransaction() {
    const data = {
      date: document.getElementById('date').value || new Date().toLocaleDateString(),
      merchant: document.getElementById('merchant').value || "Unknown",
      amount: parseFloat(document.getElementById('amount').value) || 0,
      source: document.getElementById('source').value
    };

    transactions.push(data);
    localStorage.setItem('morgenroth_data', JSON.stringify(transactions));
    updateUI();
    
    // Clear inputs
    document.getElementById('merchant').value = "";
    document.getElementById('amount').value = "";
  }

  // Load on start
  window.onload = updateUI;
</script>

</body>
</html>
